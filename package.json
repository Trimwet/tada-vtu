{
  "name": "tada-vtu",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "mobile",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --webpack",
    "start": "next start",
    "whatsapp:baileys": "bun run src/scripts/whatsapp-baileys.ts",
    "whatsapp:seed": "bun run src/scripts/seed-baileys-session.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "type-check": "tsc --noEmit",
    "check-all": "bun run type-check && bun run lint",
    "errors": "node check-errors.js",
    "analyze": "ANALYZE=true bun run build",
    "lighthouse": "node scripts/lighthouse-audit.js",
    "perf-test": "bun run build && bun run lighthouse",
    "optimize": "bun run lint:fix && bun run type-check && bun run build",
    "build:fast": "NODE_ENV=production next build --no-lint --experimental-build-mode=compile",
    "preload-critical": "node scripts/preload-critical-resources.js",
    "compress-images": "node scripts/compress-images.js",
    "perf-audit": "bun run build && bun run lighthouse && bun run analyze",
    "build:prod": "NODE_ENV=production next build --no-lint",
    "start:prod": "NODE_ENV=production next start",
    "perf:analyze": "bun run build && bun run analyze",
    "perf:lighthouse": "bun run build && bun run lighthouse",
    "perf:full": "bun run lint:fix && bun run type-check && bun run build:prod && bun run lighthouse"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@lottiefiles/dotlottie-react": "^0.18.6",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.15",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.86.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/qrcode": "^1.5.6",
    "@types/web-push": "^3.6.4",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "@yudiel/react-qr-scanner": "^2.5.1",
    "autoprefixer": "^10.4.22",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "gsap": "^3.14.2",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.555.0",
    "motion": "^12.35.1",
    "next": "^16.1.6",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.75.0",
    "react-svg-credit-card-payment-icons": "^5.1.2",
    "recharts": "^3.6.0",
    "resend": "^6.6.0",
    "sonner": "^2.0.7",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "twemoji-parser": "^14.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "web-vitals": "^5.1.0"
  }
}
